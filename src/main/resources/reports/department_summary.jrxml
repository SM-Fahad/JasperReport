<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="department_summary" pageWidth="595" pageHeight="842" columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <field name="department" class="java.lang.String"/>
    <field name="salary" class="java.lang.Double"/>

    <group name="DepartmentGroup">
        <groupExpression><![CDATA[$F{department}]]></groupExpression>
        <groupHeader>
            <band height="30">
                <rectangle>
                    <reportElement x="0" y="0" width="555" height="30" backcolor="#3498DB"/>
                </rectangle>
                <textField>
                    <reportElement x="10" y="5" width="300" height="20" forecolor="#FFFFFF"/>
                    <textFieldExpression><![CDATA["Department: " + $F{department}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="25">
                <textField pattern="#,##0.00">
                    <reportElement x="400" y="0" width="150" height="25" backcolor="#F1C40F"/>
                    <textFieldExpression><![CDATA["Total Salary: " + $V{DepartmentSalarySum}]]></textFieldExpression>
                </textField>
            </band>
        </groupFooter>
    </group>

    <variable name="DepartmentSalarySum" class="java.lang.Double" resetType="Group" resetGroup="DepartmentGroup" calculation="Sum">
        <variableExpression><![CDATA[$F{salary}]]></variableExpression>
    </variable>

    <detail>
        <band height="20">
            <textField><reportElement x="30" y="0" width="200" height="20"/><textFieldExpression><![CDATA[$F{department}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="350" y="0" width="100" height="20"/><textFieldExpression><![CDATA[$F{salary}]]></textFieldExpression></textField>
        </band>
    </detail>
</jasperReport>
