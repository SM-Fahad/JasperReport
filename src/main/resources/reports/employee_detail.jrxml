<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="employee_detail" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <parameter name="employeeId" class="java.lang.Long"/>
    <field name="id" class="java.lang.Long"/>
    <field name="name" class="java.lang.String"/>
    <field name="department" class="java.lang.String"/>
    <field name="salary" class="java.lang.Double"/>
    <field name="email" class="java.lang.String"/>

    <title>
        <band height="70">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="70" backcolor="#8E44AD"/>
            </rectangle>
            <textField>
                <reportElement x="20" y="20" width="515" height="30" forecolor="#FFFFFF" fontSize="18"/>
                <textFieldExpression><![CDATA["Employee Details"]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <detail>
        <band height="120">
            <staticText><reportElement x="30" y="20" width="100" height="20"/><text><![CDATA[Employee ID:]]></text></staticText>
            <textField><reportElement x="150" y="20" width="200" height="20"/><textFieldExpression><![CDATA[$F{id}]]></textFieldExpression></textField>

            <staticText><reportElement x="30" y="45" width="100" height="20"/><text><![CDATA[Name:]]></text></staticText>
            <textField><reportElement x="150" y="45" width="200" height="20"/><textFieldExpression><![CDATA[$F{name}]]></textFieldExpression></textField>

            <staticText><reportElement x="30" y="70" width="100" height="20"/><text><![CDATA[Department:]]></text></staticText>
            <textField><reportElement x="150" y="70" width="200" height="20"/><textFieldExpression><![CDATA[$F{department}]]></textFieldExpression></textField>

            <staticText><reportElement x="30" y="95" width="100" height="20"/><text><![CDATA[Email:]]></text></staticText>
            <textField><reportElement x="150" y="95" width="250" height="20"/><textFieldExpression><![CDATA[$F{email}]]></textFieldExpression></textField>

            <staticText><reportElement x="30" y="120" width="100" height="20"/><text><![CDATA[Salary:]]></text></staticText>
            <textField pattern="#,##0.00"><reportElement x="150" y="120" width="100" height="20"/><textFieldExpression><![CDATA[$F{salary}]]></textFieldExpression></textField>
        </band>
    </detail>
</jasperReport>
